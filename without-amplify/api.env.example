# /etc/interviewcoach/api.env
# Solution SANS Amplify — secrets de l'API .NET
#
# Sur EC2 : chmod 600, chown root:root
# NE JAMAIS commiter ce fichier avec de vraies clés
#
# Copier sur EC2 et remplir :
#   sudo cp api.env.example /etc/interviewcoach/api.env
#   sudo nano /etc/interviewcoach/api.env
#   sudo chmod 600 /etc/interviewcoach/api.env
#   sudo chown root:root /etc/interviewcoach/api.env

ASPNETCORE_URLS=http://127.0.0.1:5000
ASPNETCORE_ENVIRONMENT=Production

# Fournisseur IA : claude | gemini | ollama | fake
AI_PROVIDER=claude

# Clé Anthropic (si AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-api03-REMPLACER

# Clé Gemini (si AI_PROVIDER=gemini)
# GEMINI_API_KEY=REMPLACER
# GEMINI_MODEL=models/gemini-2.5-flash

# Ollama (si AI_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.3
