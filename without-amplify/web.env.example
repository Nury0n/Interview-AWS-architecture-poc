# /etc/interviewcoach/web.env
# Solution SANS Amplify — environnement runtime Next.js
#
# IMPORTANT : NEXT_PUBLIC_API_URL est gravée dans le bundle JS au moment
# du build (npm run build). La modifier ici n'a aucun effet sur une app
# déjà buildée. Pour changer l'URL : modifier src/web/.env.production,
# rebuilder, et redéployer avec : ./deploy.sh web
#
# Ce fichier contrôle uniquement PORT et HOSTNAME du serveur Node.js.

NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1
